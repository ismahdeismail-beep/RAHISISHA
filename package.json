{
  "name": "rahisisha-platform",
  "version": "1.0.0",
  "description": "RAHISISHA - Unified Payment Platform for Africa",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "cron": "node dist/cron/subscription-cron.js",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "keywords": ["payments", "mpesa", "braintree", "pesapal", "africa", "fintech"],
  "author": "RAHISISHA Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2", "mongoose": "^8.0.0", "redis": "^4.6.0", "ioredis": "^5.3.0",
    "braintree": "^3.20.0", "axios": "^1.6.0", "jsonwebtoken": "^9.0.0", "bcryptjs": "^2.4.3",
    "dotenv": "^16.3.0", "cors": "^2.8.5", "helmet": "^7.1.0", "express-rate-limit": "^7.1.0",
    "winston": "^3.11.0", "joi": "^17.11.0", "node-cron": "^3.0.3", "uuid": "^9.0.0",
    "crypto-js": "^4.2.0", "nodemailer": "^6.9.0", "twilio": "^4.19.0", "bull": "^4.12.0",
    "compression": "^1.7.4", "morgan": "^1.10.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21", "@types/node": "^20.10.0", "@types/jsonwebtoken": "^9.0.5",
    "@types/bcryptjs": "^2.4.6", "@types/cors": "^2.8.16", "@types/compression": "^1.7.5",
    "@types/morgan": "^1.9.9", "@types/uuid": "^9.0.7", "@types/crypto-js": "^4.2.1",
    "@types/node-cron": "^3.0.11", "typescript": "^5.3.0", "ts-node": "^10.9.0",
    "ts-node-dev": "^2.0.0", "jest": "^29.7.0", "@types/jest": "^29.5.0",
    "ts-jest": "^29.1.0", "supertest": "^6.3.0", "@types/supertest": "^6.0.0",
    "eslint": "^8.54.0", "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.12.0"
  },
  "engines": { "node": ">=18.0.0" }
}